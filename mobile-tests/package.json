{
  "name": "mobile-tests",
  "version": "1.0.0",
  "description": "Mobile application testing suite",
  "main": "index.js",
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:android": "wdio run wdio.conf.js --spec android",
    "test:ios": "wdio run wdio.conf.js --spec ios",
    "performance": "lighthouse http://localhost:5173 --output=json --output-path=./reports/lighthouse.json --emulated-form-factor=mobile",
    "accessibility": "axe http://localhost:5173 --save ./reports/accessibility.json",
    "report": "allure generate ./allure-results --clean && allure open"
  },
  "dependencies": {
    "@wdio/allure-reporter": "^8.32.0",
    "@wdio/appium-service": "^8.32.0",
    "allure-mocha": "^2.10.0",
    "appium": "^2.5.1",
    "appium-uiautomator2-driver": "^2.34.1",
    "axe-core": "^4.9.1",
    "lighthouse": "^12.0.0",
    "puppeteer": "^22.0.0",
    "webdriverio": "^8.32.0"
  },
  "devDependencies": {
    "@wdio/mocha-framework": "^8.32.0",
    "@wdio/spec-reporter": "^8.32.0"
  }
}</content>
